{
  "name": "maplat-editor",
  "private": true,
  "version": "0.7.0",
  "description": "Maplat Editor - Historical Map Georeferencing Tool",
  "author": "Maplat Project",
  "type": "module",
  "scripts": {
    "dev": "node -e \"process.platform==='win32'&&require('child_process').execSync('chcp 65001')\" && vite",
    "preview": "vite preview",
    "build": "vue-tsc && vite build",
    "dist": "pnpm run build && electron-builder --config electron-builder.config.cjs",
    "dist:mac": "pnpm run build && electron-builder --config electron-builder.config.cjs --mac",
    "dist:mac:x64": "pnpm run build && electron-builder --config electron-builder.config.cjs --mac --x64",
    "dist:mac:arm64": "pnpm run build && electron-builder --config electron-builder.config.cjs --mac --arm64",
    "dist:mac:universal": "pnpm run build && electron-builder --config electron-builder.config.cjs --mac --universal",
    "dist:win": "pnpm run build && electron-builder --config electron-builder.config.cjs --win",
    "dist:win:x64": "pnpm run build && electron-builder --config electron-builder.config.cjs --win --x64",
    "dist:win:arm64": "pnpm run build && electron-builder --config electron-builder.config.cjs --win --arm64",
    "dist:linux": "pnpm run build && electron-builder --config electron-builder.config.cjs --linux",
    "dist:linux:x64": "pnpm run build && electron-builder --config electron-builder.config.cjs --linux --x64",
    "dist:linux:arm64": "pnpm run build && electron-builder --config electron-builder.config.cjs --linux --arm64"
  },
  "dependencies": {
    "@maplat/core": "^0.13.0",
    "adm-zip": "^0.5.9",
    "@maplat/tin": "^0.13.1",
    "@maplat/transform": "^0.4.1",
    "@popperjs/core": "^2.11.8",
    "@seald-io/nedb": "^4.1.2",
    "@types/geojson": "^7946.0.16",
    "@types/lodash-es": "^4.17.12",
    "bootstrap": "^5.3.8",
    "bootstrap-icons": "^1.13.1",
    "electron-store": "^11.0.2",
    "file-url": "^4.0.0",
    "fs-extra": "^11.3.3",
    "i18next": "^25.8.5",
    "i18next-http-backend": "^3.0.2",
    "i18next-vue": "^5.4.0",
    "jimp": "^1.6.0",
    "lodash-es": "^4.17.23",
    "ol": "^10.7.0",
    "ol-contextmenu": "^6.0.0",
    "ol-geocoder": "^4.3.3",
    "ol-layerswitcher": "^4.1.2",
    "vue": "^3.4.21",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@electron/notarize": "^2.5.0",
    "@types/file-url": "^3.0.4",
    "@types/fs-extra": "^11.0.4",
    "@types/nedb": "^1.8.16",
    "@vitejs/plugin-vue": "^5.0.4",
    "dotenv": "^16.0.1",
    "electron": "^30.0.1",
    "electron-builder": "^24.13.3",
    "sass": "^1.97.3",
    "typescript": "^5.2.2",
    "vite": "^5.1.6",
    "vite-plugin-electron": "^0.28.6",
    "vite-plugin-electron-renderer": "^0.14.5",
    "vite-plugin-node-polyfills": "^0.25.0",
    "vue-tsc": "^2.0.26"
  },
  "main": "dist-electron/main.js"
}
